// This program will allow 2 players to play a game of Checkers

import java.util.Scanner;

public class CSFinalCheckers{
    public static void main(String args[])
    throws java.lang.InterruptedException{
        Scanner sc = new Scanner(System.in);

        String directions, p1, p2;
        int mistakeCount1=0, mistakeCount2=0, noCount=0;        //counters are for each player
        int rowCount=0;
        boolean direct=false, finished=false;
        String space[][]=new String [9][9];  //8 rows, 8 columns
        String seen[][]=new String [9][9];  //8 rows, 8 columns but it's for what the player sees

        //Directions
        System.out.println("Welcome to Checkers!\nPlease read these directions and indicate whether or not you understand the directions before playing.\n");
        while(direct==false){
            System.out.println("Directions:\n~Checkers is a 2-player game (typically black vs red; this game will be black vs white). Each player has 12 pieces.\n~Pieces can only move in a forward diagonal direction, one space at a time\n\t(reference: in chess, a bishop can move along its diagonal as many spaces/rows as it'd like but in checkers, it can only be one space at a time unless...)");
            Thread.sleep(1000);
            System.out.println("\nHow to win:\n~Capture all of your opponent's pieces or block all of their pieces from moving. If your opponent's piece is in an adjacent space diagonal to and in front of one\n of your pieces and the next space in that diagonal is open, your piece MUST jump over the opponent's piece and 'kill' that piece.\n\tThis is called capturing a piece. Any time that you have a chance to capture a piece, you MUST capture it.");
            //Note: we're gonna need error messages to show whether or not something can be captured b/c if it can, the player HAS to capture
            //Note: maybe show a demonstration of this would be cool? Should be added at the end tho once we actually figure out the board
            Thread.sleep(1000);
            System.out.println("~If you take a piece just to realize you are in position to take another piece right away, then you MUST take that piece as well, resulting in a double jump or\n 'double kill'. If you can capture another piece right away, you must do a triple jump, and so on.\n\tConsecutive jumps do not need to be in the same direction!");
            //Note: again, a demo might be nice. 
            Thread.sleep(1000);
            System.out.println("~As previously mentioned, pieces can only move forward diagonally unless... the piece reaches the very last row. Then the piece becomes a king and is able to move\n forwards and backwards, diagonally!");
            System.out.println("\tA king can be captured like a regular piece, must capture when possible, and must make consecutive jumps when possible.");
            Thread.sleep(1000);
            System.out.println("\nAgain, you win by capturing all of your opponent's pieces or by blocking all their pieces, leaving them with no other moves and needing to forfeit.");
            System.out.print("\nHave both of you understood the directions? (Y/N) ");
            directions = sc.next();

            if(directions.equalsIgnoreCase("Y")){
                System.out.print("\f");
                break;
            }
            else{
                noCount++;
                if(noCount==10){
                    System.out.println("\nYou have struggled to understand the directions for this game " + noCount + " times. I encourage you to play an easier game instead.\n\n\tGood-bye!");
                    break;
                }
                System.out.print("\f");
                Thread.sleep(1500);
            }
        }

        //Space array key: 0=empty, 1=black pawn, 2=white pawn, 3=black king, 4=white king
        
        //Initialize arrays
        for(int row=0; row<space.length; row++)     //defaults everything to '0' aka empty
            for(int column=0; column<space[row].length; column++)
                space[row][column]="0 ";

        for(int row=0; row<space.length; row++)
            space[row][0]=row + "\t";
        for(int column=1; column<space[0].length; column++)
            space[0][column]=column + " ";

        for(int column=1; column<space[0].length; column+=2){       //these pieces start from column 1 in-game
            space[1][column]="1 ";
            space[3][column]="1 ";
            space[6][column]="2 ";
            space[8][column]="2 ";
        }
        for(int column=2; column<space[0].length; column+=2){       //these pieces start from column 2 in-game
            space[2][column]="1 ";
            space[7][column]="2 ";
        }

        //Game
        while(finished==false){
            //Prints (hidden atm) board
            for(int column=0; column<space[0].length; column++)
                System.out.print(space[0][column]);
            System.out.println("\n");
            for(int row=1; row<space.length; row++){
                for(int column=0; column<space[row].length; column++)
                    System.out.print(space[row][column]);
                System.out.println();
            }

        }
    }
}
